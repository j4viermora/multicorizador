# Copy to .env for local development. Production values go in the deploy
# panel's environment variables, never in this file.
#
# Local development only needs OMINT_CLIENT_SECRET — the database defaults in
# config/database.yml already match docker-compose.yml.

# ---------------------------------------------------------------------------
# Development
# ---------------------------------------------------------------------------

# Omint provider credential, seeded into providers.config by db/seeds.rb.
# Value comes from the Omint integration manual (PDF).
OMINT_CLIENT_SECRET=

# Override only if you changed docker-compose.yml.
# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_USERNAME=ruka
# DB_PASSWORD=password

# ---------------------------------------------------------------------------
# Production — set these in the deploy panel
# ---------------------------------------------------------------------------

# Rails credentials key. Required.
# RAILS_MASTER_KEY=

# Database. Deliberately NOT named DATABASE_URL — Rails auto-merges that one
# into the primary config and lets the URL scheme override the adapter, which
# breaks on "mariadb://" URLs. See the comment in config/database.yml.
# APP_DATABASE_URL=mysql2://user:password@host:3306/dbname

# Cloudflare R2 (Active Storage). The endpoint is the ACCOUNT url — do not
# append the bucket name to it, the bucket is passed separately.
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=ruka-prod
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Public hostname, used to build links in outgoing email.
# APP_HOST=app.example.com

# Transactional email.
# RESEND_API_KEY=

# Optional tuning.
# WEB_CONCURRENCY=2
# JOB_CONCURRENCY=3
# RAILS_MAX_THREADS=5
# RAILS_LOG_LEVEL=info
