<h1 class="text-3xl font-bold mb-6">Editar perfil</h1>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "bg-white p-6 rounded-lg shadow max-w-lg" }) do |f| %>
  <%= f.error_notification %>

  <%= f.input :email, label: "Correo electrónico",
              input_html: { autofocus: true, autocomplete: "email" } %>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div class="alert alert-info mb-4 text-sm">
      Esperando confirmación para: <%= resource.unconfirmed_email %>
    </div>
  <% end %>

  <%= f.input :password, label: "Nueva contraseña",
              hint: "Déjalo en blanco si no quieres cambiarla#{" (mínimo #{@minimum_password_length} caracteres)" if @minimum_password_length}",
              input_html: { autocomplete: "new-password" }, required: false %>

  <%= f.input :password_confirmation, label: "Confirmar nueva contraseña",
              input_html: { autocomplete: "new-password" }, required: false %>

  <%= f.input :current_password, label: "Contraseña actual",
              hint: "Necesitamos tu contraseña actual para confirmar los cambios",
              input_html: { autocomplete: "current-password" } %>

  <div class="flex gap-2 mt-6">
    <%= f.button :submit, "Actualizar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", :back, class: "btn btn-ghost" %>
  </div>
<% end %>

<div class="mt-10 p-6 bg-white rounded-lg shadow max-w-lg border border-red-200">
  <h3 class="text-lg font-semibold text-red-600 mb-2">Cancelar mi cuenta</h3>
  <p class="text-sm text-gray-500 mb-4">Esta acción es irreversible.</p>
  <%= button_to "Eliminar mi cuenta", registration_path(resource_name),
      method: :delete, class: "btn btn-error btn-outline btn-sm",
      data: { turbo_confirm: "¿Estás seguro? Esta acción no se puede deshacer." } %>
</div>
