<% content_for :full_screen, true %>

<div class="flex h-screen overflow-hidden">

  <%# ── Left Hero Panel (3/4) ── %>
  <div class="hidden lg:flex lg:w-3/4 relative flex-col justify-between p-14 overflow-hidden bg-linear-to-br from-[#0d0b1e] via-[#2d1b69] to-[#1e3a5f]">

    <div class="absolute -top-24 -left-20 w-md h-112 rounded-full bg-purple-500/20 blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-16 right-10 w-80 h-80 rounded-full bg-blue-400/20 blur-3xl animate-pulse [animation-delay:2s]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-pink-400/10 blur-3xl animate-pulse [animation-delay:4s]"></div>

    <div class="relative z-10">
      <span class="font-sans text-white/90 text-xs tracking-[0.35em] uppercase">RUKA</span>
    </div>

    <div class="relative z-10">
      <p class="font-sans text-white/35 text-xs tracking-[0.2em] uppercase mb-5">Bienvenido de vuelta</p>
      <h1 class="font-serif text-6xl text-white font-light leading-tight mb-6">
        Tu Ruka<br><em>de seguros</em>
      </h1>
      <p class="font-sans text-white/40 text-sm font-light leading-relaxed max-w-md">
        Cotiza, compara y emite pólizas de seguro de viaje con múltiples proveedores desde un solo lugar.
      </p>
      <div class="flex items-center gap-3 mt-10">
        <div class="w-10 h-px bg-white/25"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-white/30"></div>
        <div class="w-4 h-px bg-white/15"></div>
      </div>
    </div>
  </div>

  <%# ── Right Form Panel (1/4) ── %>
  <div class="w-full lg:w-1/4 flex flex-col justify-center bg-white px-10 overflow-y-auto">

    <div class="lg:hidden mb-10">
      <span class="font-sans text-xs tracking-[0.35em] uppercase text-gray-900">RUKA</span>
    </div>

    <div class="mb-9">
      <h2 class="font-serif text-3xl font-light text-gray-900 mb-1">Iniciar sesión</h2>
      <p class="font-sans text-xs text-gray-500">Ingresa tus credenciales para continuar</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "flex flex-col gap-5" }) do |f| %>

      <%= f.input :email, label: "Correo electrónico", placeholder: "nombre@correo.com",
                  wrapper: :auth, input_html: { autofocus: true, autocomplete: "email" } %>

      <%= f.input :password, label: "Contraseña", placeholder: "••••••••",
                  wrapper: :auth, input_html: { autocomplete: "current-password" } %>

      <% if devise_mapping.rememberable? %>
        <%= f.input :remember_me, as: :boolean, label: "Recordarme" %>
      <% end %>

      <%= f.button :submit, "Entrar →", class: "btn btn-neutral w-full mt-2 text-xs tracking-widest uppercase" %>

    <% end %>

    <div class="mt-8 pt-6 border-t border-gray-200 flex flex-col gap-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
