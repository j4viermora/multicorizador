<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title>Cotización - Asisto</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-base-200">
    <div class="container mx-auto px-4 py-8 max-w-2xl">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-primary">Asisto</h1>
        <p class="text-gray-500">Cotización de seguro de viaje</p>
      </div>

      <% if notice %>
        <div class="alert alert-success mb-4"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-error mb-4"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
