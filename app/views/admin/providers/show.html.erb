<h1 class="text-3xl font-bold mb-6"><%= @provider.name %></h1>

<div class="bg-base-100 p-6 rounded-box shadow max-w-lg mb-6">
  <p><strong>Slug:</strong> <code><%= @provider.slug %></code></p>
  <p><strong>Estado:</strong> <span class="badge badge-<%= @provider.active? ? 'success' : 'error' %>"><%= @provider.status %></span></p>
  <p><strong>Config:</strong></p>
  <pre class="bg-base-200 p-2 rounded text-sm overflow-auto"><%= JSON.pretty_generate(@provider.config) %></pre>
</div>

<%= link_to "Editar", edit_admin_provider_path(@provider), class: "btn btn-primary" %>
<%= link_to "Volver", admin_providers_path, class: "btn btn-ghost" %>
