<h1 class="text-3xl font-bold mb-2">Póliza <%= @policy.policy_number %></h1>
<p class="text-gray-500 mb-6">Emitida el <%= l @policy.issued_at, format: :long if @policy.issued_at %></p>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="card">
    <div class="card-body">
      <h2 class="card-title">Detalles</h2>
      <p><strong>Proveedor:</strong> <%= @policy.quote_result.provider.name %></p>
      <p><strong>Vigencia:</strong> <%= l @policy.starts_at if @policy.starts_at %> - <%= l @policy.ends_at if @policy.ends_at %></p>
      <p><strong>Prima:</strong> <%= @policy.premium.format %></p>
      <p><strong>Total:</strong> <%= @policy.total.format %></p>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h2 class="card-title">Canal</h2>
      <p>
        <span class="badge <%= @policy.sold_via == 'direct' ? 'badge-primary' : 'badge-info' %>">
          <%= @policy.sold_via == "direct" ? "Ruka directo" : "Producer" %>
        </span>
      </p>
      <% if @policy.sold_via != "direct" && @policy.producer %>
        <p class="mt-2"><strong>Producer:</strong> <%= @policy.producer.full_name %></p>
      <% end %>
      <h2 class="card-title mt-4">Estado</h2>
      <p><span class="badge badge-<%= @policy.active? ? 'success' : 'ghost' %>"><%= @policy.status.humanize %></span></p>
    </div>
  </div>
</div>

<div class="mt-8">
  <%= link_to "Volver", admin_policies_path, class: "btn btn-ghost" %>
</div>
