<h1 class="text-3xl font-bold mb-6">Facturas a Aseguradoras</h1>

<%= link_to "Nueva Factura", new_admin_platform_invoice_path, class: "btn btn-primary mb-4" %>

<div class="overflow-x-auto bg-base-100 shadow rounded-box">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>Proveedor</th>
        <th>Período</th>
        <th>Total</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @invoices.each do |invoice| %>
        <tr>
          <td><%= invoice.provider.name %></td>
          <td><%= l invoice.period_start %> - <%= l invoice.period_end %></td>
          <td><%= invoice.total_commission.format %></td>
          <td>
            <span class="badge badge-<%= invoice.draft? ? 'ghost' : invoice.pending? ? 'warning' : 'success' %>">
              <%= invoice.status.humanize %>
            </span>
          </td>
          <td>
            <%= link_to "Editar", edit_admin_platform_invoice_path(invoice), class: "btn btn-sm btn-outline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
