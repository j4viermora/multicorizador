<h1 class="text-3xl font-bold mb-6">Nueva Factura</h1>

<%= simple_form_for [:admin, @invoice], html: { class: "bg-base-100 p-6 rounded-box shadow max-w-lg" } do |f| %>
  <%= f.association :provider, include_blank: false %>
  <%= f.input :period_start, as: :date %>
  <%= f.input :period_end, as: :date %>
  <%= f.input :status, collection: %w[draft pending paid], include_blank: false %>

  <div class="flex gap-2">
    <%= f.button :submit, "Guardar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_platform_invoices_path, class: "btn btn-ghost" %>
  </div>
<% end %>
