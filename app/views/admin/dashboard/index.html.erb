<h1 class="text-3xl font-bold mb-6">Panel de Administración</h1>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
  <div class="stat">
    <div class="stat-title">Productores Pendientes</div>
    <div class="stat-value text-amber-600"><%= @pending_producers_count %></div>
    <div class="stat-desc"><%= link_to "Ver productores", admin_users_path, class: "link" %></div>
  </div>

  <div class="stat">
    <div class="stat-title">Proveedores</div>
    <div class="stat-value text-teal-600"><%= @total_providers %></div>
    <div class="stat-desc"><%= link_to "Gestionar proveedores", admin_providers_path, class: "link" %></div>
  </div>

  <div class="stat">
    <div class="stat-title">Pólizas Ruka Directo</div>
    <div class="stat-value text-green-600"><%= @total_policies_direct %></div>
    <div class="stat-desc"><%= link_to "Ver pólizas", admin_policies_path(q: { sold_via_eq: "direct" }), class: "link" %></div>
  </div>

  <div class="stat">
    <div class="stat-title">Pólizas Producers</div>
    <div class="stat-value text-blue-600"><%= @total_policies_producer %></div>
    <div class="stat-desc">
      <% if @total_policies_producer.zero? %>
        Aún no hay ventas por productores afiliados
      <% else %>
        <%= link_to "Ver pólizas", admin_policies_path(q: { sold_via_eq: "producer" }), class: "link" %>
      <% end %>
    </div>
  </div>
</div>
