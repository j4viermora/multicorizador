<h1 class="text-3xl font-bold mb-6">Productores</h1>

<div class="overflow-x-auto bg-base-100 shadow rounded-box">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>Empresa / Slug</th>
        <th>Página pública</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.full_name %></td>
          <td><%= user.email %></td>
          <td>
            <% if user.company %>
              <span class="font-mono text-sm"><%= user.company.slug %></span>
            <% else %>
              <span class="text-base-content/40">—</span>
            <% end %>
          </td>
          <td>
            <% if user.company&.slug.present? %>
              <% public_url = public_landing_url(slug: user.company.slug) %>
              <div class="flex items-center gap-2">
                <%= link_to public_url, target: "_blank", class: "link link-primary text-sm truncate max-w-48" do %>
                  /cotizar/<%= user.company.slug %>
                <% end %>
                <button class="btn btn-xs btn-ghost"
                        onclick="navigator.clipboard.writeText('<%= public_url %>').then(() => { this.textContent = '✓'; setTimeout(() => this.textContent = '⎘', 1200) })"
                        title="Copiar enlace">⎘</button>
              </div>
            <% else %>
              <span class="text-base-content/40">Sin slug</span>
            <% end %>
          </td>
          <td>
            <span class="badge badge-<%= user.pending? ? 'warning' : user.active? ? 'success' : 'error' %>">
              <%= user.status.humanize %>
            </span>
          </td>
          <td class="flex gap-2">
            <% if user.pending? %>
              <%= button_to "Aprobar", approve_admin_user_path(user), method: :patch, class: "btn btn-sm btn-success" %>
            <% end %>
            <%= link_to "Editar", edit_admin_user_path(user), class: "btn btn-sm btn-outline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
