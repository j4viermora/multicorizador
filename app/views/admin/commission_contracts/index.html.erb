<h1 class="text-3xl font-bold mb-6">Contratos de Comisión</h1>

<%= link_to "Nuevo Contrato", new_admin_commission_contract_path, class: "btn btn-primary mb-4" %>

<div class="overflow-x-auto bg-base-100 shadow rounded-box">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>Proveedor</th>
        <th>Productor</th>
        <th>Comisión Aseguradora</th>
        <th>% al Productor</th>
        <th>Vigente</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @contracts.each do |contract| %>
        <tr>
          <td><%= contract.provider.name %></td>
          <td><%= contract.producer&.full_name || "Default (todos)" %></td>
          <td><%= number_to_percentage(contract.provider_commission_rate * 100, precision: 1) %></td>
          <td><%= number_to_percentage(contract.producer_share_rate * 100, precision: 1) %></td>
          <td><%= l contract.valid_from %> <%= "- #{l contract.valid_until}" if contract.valid_until %></td>
          <td>
            <%= link_to "Editar", edit_admin_commission_contract_path(contract), class: "btn btn-sm btn-outline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
