<h1 class="text-3xl font-bold mb-6">Editar Contrato</h1>

<%= simple_form_for [:admin, @contract], html: { class: "bg-base-100 p-6 rounded-box shadow max-w-lg" } do |f| %>
  <%= f.association :provider, include_blank: false %>
  <%= f.association :producer, collection: User.active_producers, label: "Productor", include_blank: "Default (todos)" %>
  <%= f.input :provider_commission_rate, label: "% Comisión Aseguradora", input_html: { step: 0.01, min: 0, max: 1 } %>
  <%= f.input :producer_share_rate, label: "% al Productor", input_html: { step: 0.01, min: 0, max: 1 } %>
  <%= f.input :valid_from, as: :date %>
  <%= f.input :valid_until, as: :date, include_blank: true %>

  <div class="flex gap-2">
    <%= f.button :submit, "Actualizar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_commission_contracts_path, class: "btn btn-ghost" %>
  </div>
<% end %>
