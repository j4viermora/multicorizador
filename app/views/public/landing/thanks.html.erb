<% content_for(:head) do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>.wizard-root, .wizard-root * { font-family: 'Outfit', sans-serif; }</style>
<% end %>

<div class="wizard-root max-w-lg mx-auto py-8">
  <div class="wizard-card p-8 md:p-12 text-center wizard-animate-in">
    <%# Success icon %>
    <div class="mx-auto mb-6" style="width: 4rem; height: 4rem; border-radius: 50%; background: var(--wz-teal-light); display: flex; align-items: center; justify-content: center;">
      <svg xmlns="http://www.w3.org/2000/svg" style="color: var(--wz-teal);" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="wizard-section-title text-2xl mb-2">¡Cotización enviada!</h1>
    <p class="wizard-section-subtitle mb-6">
      Estamos consultando a los mejores proveedores de seguros de viaje.
      Pronto recibirás las opciones disponibles.
    </p>

    <div class="wizard-optional-section p-4 text-left mb-6">
      <div class="grid grid-cols-2 gap-y-2 text-sm">
        <span style="color: var(--wz-ink-muted);">Origen</span>
        <span class="font-semibold" style="color: var(--wz-ink);"><%= @quote.origin %></span>
        <span style="color: var(--wz-ink-muted);">Destino</span>
        <span class="font-semibold" style="color: var(--wz-ink);"><%= @quote.destination %></span>
        <span style="color: var(--wz-ink-muted);">Salida</span>
        <span class="font-semibold" style="color: var(--wz-ink);"><%= l(@quote.departure_date, format: :long) rescue @quote.departure_date %></span>
        <% if @quote.return_date %>
          <span style="color: var(--wz-ink-muted);">Regreso</span>
          <span class="font-semibold" style="color: var(--wz-ink);"><%= l(@quote.return_date, format: :long) rescue @quote.return_date %></span>
        <% end %>
        <span style="color: var(--wz-ink-muted);">Pasajeros</span>
        <span class="font-semibold" style="color: var(--wz-ink);"><%= @quote.travelers_count %></span>
      </div>
    </div>

    <p class="text-xs" style="color: var(--wz-ink-muted);">
      Cotización #<%= @quote.public_token&.first(8) %> &mdash; <%= @company.name %>
    </p>
  </div>

  <div class="text-center mt-8 text-xs" style="color: var(--wz-ink-muted);">
    Powered by <strong>Asisto</strong> &mdash; Multicotizador de seguros de viaje
  </div>
</div>
