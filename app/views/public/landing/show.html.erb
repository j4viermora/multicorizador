<% content_for(:head) do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@23.8.1/build/css/intlTelInput.min.css">
  <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.8.1/build/js/intlTelInput.min.js"></script>
<% end %>
<style>
  .landing-root, .landing-root * { font-family: 'Outfit', sans-serif; }

  /* ── Hero: color plano, sin degradados ── */
  .landing-hero {
    background: var(--wz-hero);
    position: relative;
  }

  /* ── Producer card ── */
  .producer-card {
    background: var(--wz-hero-soft);
    border: 1px solid var(--wz-hero-line);
    border-radius: 0.5rem;
  }
  .producer-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.4rem;
    background: var(--wz-teal);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  /* ── Trust bar ── */
  .trust-bar {
    background: white;
    border: 1px solid var(--wz-border);
    border-radius: 0.5rem;
  }
  .trust-provider {
    padding: 0.35rem 0.75rem;
    border-radius: 0.25rem;
    background: var(--wz-sand);
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--wz-ink-soft);
    white-space: nowrap;
  }

  /* ── Benefits ── */
  .benefit-card {
    background: white;
    border: 1px solid var(--wz-border);
    border-radius: 0.5rem;
    padding: 1rem;
    transition: border-color 0.15s ease;
  }
  .benefit-card:hover { border-color: var(--wz-teal); }
  .benefit-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.6rem;
  }

  /* ── Footer ── */
  .landing-footer {
    border-top: 1px solid var(--wz-border);
    color: var(--wz-ink-muted);
  }

  /* ── Stagger animations ── */
  @keyframes landing-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .land-in {
    animation: landing-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .land-in.d1 { animation-delay: 0.1s; }
  .land-in.d2 { animation-delay: 0.2s; }
  .land-in.d3 { animation-delay: 0.3s; }
  .land-in.d4 { animation-delay: 0.4s; }
  .land-in.d5 { animation-delay: 0.5s; }

  /* ── intl-tel-input dentro de una celda de la barra ── */
  .qbar-field .iti {
    width: 100%;
    display: flex;
    border: none;
    background: transparent;
  }
  /* La bandera va absoluta a la izquierda: hay que dejarle su espacio */
  .qbar-field .iti__tel-input {
    padding-left: 2.85rem !important;
    padding-right: 0 !important;
  }
  .qbar-field .iti__country-container { padding: 0; }
  .iti__dropdown-content { font-family: 'Outfit', sans-serif; }
</style>
<div class="landing-root">
  <%# ══════════════════════════════════════════════ %>
  <%# HERO + COTIZADOR                              %>
  <%# ══════════════════════════════════════════════ %>
  <div class="landing-hero -mx-4 -mt-8 px-4 pt-8 pb-10 md:pt-10 md:pb-12 relative">
    <div class="max-w-2xl lg:max-w-6xl mx-auto relative z-10">
      <%# Título %>
      <div class="text-center mb-5 land-in">
        <h1 class="text-2xl md:text-3xl font-bold text-white tracking-tight leading-tight">
          Seguro de viaje: cotizá y compará tu cobertura en segundos
        </h1>
        <p class="text-sm md:text-base mt-1.5" style="color: oklch(0.82 0.03 215);">
          <%= @company.name %> &middot; compará todas las opciones y elegí la que te sirve
        </p>
      </div>

      <%# Productor (si viene el parámetro ref) %>
      <% if @producer %>
        <div class="producer-card px-4 py-3 max-w-md mx-auto mb-5 land-in d1">
          <div class="flex items-center gap-3 mb-2">
            <div class="producer-avatar">
              <%= @producer.first_name&.first&.upcase %><%= @producer.last_name&.first&.upcase %>
            </div>
            <div>
              <p class="text-white font-bold text-sm leading-tight"><%= @producer.full_name %></p>
              <p class="text-xs font-medium" style="color: oklch(0.75 0.04 195);">Asesor de seguros</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-x-4 gap-y-1 ml-1" style="color: oklch(0.82 0.03 195);">
            <% if @producer.email.present? %>
              <a href="mailto:<%= @producer.email %>" class="flex items-center gap-1.5 text-xs font-medium hover:underline" style="color: oklch(0.82 0.03 195);">
                <i class="ti ti-mail text-sm"></i>
                <%= @producer.email %>
              </a>
            <% end %>
            <% if @producer.phone.present? %>
              <a href="https://wa.me/<%= @producer.phone.gsub(/\D/, '') %>" target="_blank" class="flex items-center gap-1.5 text-xs font-medium hover:underline" style="color: oklch(0.82 0.03 195);">
                <i class="ti ti-brand-whatsapp text-sm"></i>
                <%= @producer.phone %>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ── Barra de cotización: todo en una sola pantalla ── %>
      <div class="land-in d2" data-controller="quote-form">
        <%= simple_form_for @quote, url: public_landing_path(@company.slug, ref: params[:ref]),
            method: :post,
            html: { novalidate: true, data: { turbo: false, action: "submit->quote-form#validate" } } do |f| %>

          <%= f.hidden_field :trip_type, value: "single" %>
          <%= f.hidden_field :travelers_count, data: { quote_form_target: "count" } %>

          <div class="qbar grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12">
            <%# Origen %>
            <div data-controller="country-autocomplete"
                 data-country-autocomplete-items-value="<%= countries_autocomplete_data %>"
                 class="ac-wrapper lg:col-span-3">
              <%= f.input :origin, label: "Origen", wrapper: :qbar,
                  placeholder: "¿Desde dónde salís?",
                  input_html: {
                    required: true, autocomplete: "off",
                    data: {
                      country_autocomplete_target: "input",
                      action: "input->country-autocomplete#filter focus->country-autocomplete#open keydown->country-autocomplete#keydown focus->quote-form#clearError"
                    }
                  } %>
              <ul data-country-autocomplete-target="list" class="ac-list hidden"></ul>
            </div>

            <%# Destino %>
            <div data-controller="country-autocomplete"
                 data-country-autocomplete-items-value="<%= countries_autocomplete_data %>"
                 class="ac-wrapper lg:col-span-3">
              <%= f.input :destination, label: "Destino", wrapper: :qbar,
                  placeholder: "¿Dónde viajás?",
                  input_html: {
                    required: true, autocomplete: "off",
                    data: {
                      country_autocomplete_target: "input",
                      action: "input->country-autocomplete#filter focus->country-autocomplete#open keydown->country-autocomplete#keydown focus->quote-form#clearError"
                    }
                  } %>
              <ul data-country-autocomplete-target="list" class="ac-list hidden"></ul>
            </div>

            <%# Fechas %>
            <div class="qbar-field lg:col-span-4">
              <span class="qbar-label"><i class="ti ti-calendar-event"></i> Fecha de viaje</span>
              <div class="qbar-dates">
                <%= f.input :departure_date, label: false, as: :datepicker, wrapper: :qbar_plain,
                    placeholder: "Salida",
                    input_html: { required: true,
                                  data: { datepicker_min_value: Date.today.iso8601,
                                          action: "focus->quote-form#clearError" } } %>
                <i class="ti ti-arrow-narrow-right qbar-dates-sep"></i>
                <%= f.input :return_date, label: false, as: :datepicker, wrapper: :qbar_plain,
                    placeholder: "Regreso",
                    input_html: { data: { datepicker_min_value: Date.today.iso8601 } } %>
              </div>
            </div>

            <%# Edades %>
            <div class="qbar-field lg:col-span-2">
              <span class="qbar-label">
                <i class="ti ti-users"></i> Edades
                <button type="button" class="qbar-add ml-1"
                        aria-label="Agregar pasajero"
                        data-quote-form-target="addBtn"
                        data-action="quote-form#add">
                  <i class="ti ti-plus"></i>
                </button>
              </span>
              <div class="qbar-ages" data-quote-form-target="ages">
                <% 6.times do |i| %>
                  <div class="qbar-age" data-age-field>
                    <input type="number" name="quote[metadata][ages][]" min="0" max="120"
                           placeholder="—" required inputmode="numeric"
                           aria-label="Edad del pasajero <%= i + 1 %>"
                           data-action="focus->quote-form#clearError">
                    <button type="button" class="qbar-age-remove hidden" tabindex="-1"
                            aria-label="Quitar pasajero" data-action="quote-form#remove">
                      <i class="ti ti-x"></i>
                    </button>
                  </div>
                <% end %>
              </div>
            </div>

            <%# WhatsApp %>
            <div class="qbar-field lg:col-span-4">
              <label class="qbar-label" for="phone-input">
                <i class="ti ti-brand-whatsapp"></i> WhatsApp
              </label>
              <input type="tel" id="phone-input" placeholder="11 1234-5678" autocomplete="tel">
              <input type="hidden" name="quote[metadata][phone]" id="phone-full-value">
            </div>

            <%# Email %>
            <div class="qbar-field lg:col-span-5">
              <label class="qbar-label" for="quote-email">
                <i class="ti ti-mail"></i> Email
              </label>
              <input type="email" id="quote-email" name="quote[metadata][email]"
                     placeholder="juan@ejemplo.com" required autocomplete="email"
                     data-action="focus->quote-form#clearError">
            </div>

            <%# Cotizar %>
            <div class="lg:col-span-3">
              <button type="submit" class="qbar-submit">
                <i class="ti ti-search text-lg"></i>
                Cotizar
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <p class="text-center text-xs mt-3 land-in d3" style="color: oklch(0.75 0.03 215);">
        Cotización sin costo y sin compromiso &middot; Resultados en segundos
      </p>
    </div>
  </div>

  <%# ══════════════════════════════════════════════ %>
  <%# TRUST BAR — Proveedores                       %>
  <%# ══════════════════════════════════════════════ %>
  <% if @providers.any? %>
    <div class="max-w-2xl lg:max-w-4xl mx-auto mt-8 land-in d4">
      <div class="trust-bar px-6 py-4">
        <p class="text-center text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--wz-ink-muted);">
          Cotizamos con los mejores proveedores
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <% @providers.each do |provider| %>
            <span class="trust-provider"><%= provider.name %></span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
  <%# ══════════════════════════════════════════════ %>
  <%# BENEFITS                                      %>
  <%# ══════════════════════════════════════════════ %>
  <div class="max-w-2xl lg:max-w-4xl mx-auto mt-8 land-in d5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-5">
      <div class="benefit-card">
        <div class="benefit-icon" style="background: var(--wz-teal-light); color: var(--wz-teal);">
          <i class="ti ti-bolt text-xl"></i>
        </div>
        <p class="font-bold text-sm" style="color: var(--wz-ink);">Cotización inmediata</p>
        <p class="text-xs mt-0.5" style="color: var(--wz-ink-muted);">Resultados en segundos, sin esperas.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon" style="background: var(--wz-coral-light); color: var(--wz-coral);">
          <i class="ti ti-shield-check text-xl"></i>
        </div>
        <p class="font-bold text-sm" style="color: var(--wz-ink);">Máxima cobertura</p>
        <p class="text-xs mt-0.5" style="color: var(--wz-ink-muted);">Planes que cubren lo que necesitás.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon" style="background: var(--wz-amber-light); color: oklch(0.55 0.14 75);">
          <i class="ti ti-coin text-xl"></i>
        </div>
        <p class="font-bold text-sm" style="color: var(--wz-ink);">Mejores precios</p>
        <p class="text-xs mt-0.5" style="color: var(--wz-ink-muted);">Compará y elegí la opción ideal.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon" style="background: oklch(0.92 0.04 280); color: oklch(0.5 0.15 280);">
          <i class="ti ti-headset text-xl"></i>
        </div>
        <p class="font-bold text-sm" style="color: var(--wz-ink);">Asistencia 24/7</p>
        <p class="text-xs mt-0.5" style="color: var(--wz-ink-muted);">Soporte en cualquier parte del mundo.</p>
      </div>
    </div>
  </div>
  <%# ══════════════════════════════════════════════ %>
  <%# FOOTER                                        %>
  <%# ══════════════════════════════════════════════ %>
  <div class="max-w-2xl lg:max-w-4xl mx-auto mt-10 mb-4">
    <div class="landing-footer pt-6 pb-4 flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <div style="width: 1.5rem; height: 1.5rem; border-radius: 0.375rem; background: var(--wz-teal); display: flex; align-items: center; justify-content: center;">
          <i class="ti ti-shield-check text-xs text-white"></i>
        </div>
        <span class="text-xs font-bold" style="color: var(--wz-ink-soft);">Powered by Ruka</span>
      </div>
      <p class="text-xs" style="color: var(--wz-ink-muted);">
        Cotizador de seguros de viaje &middot; Datos protegidos
      </p>
    </div>
  </div>
</div>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const phoneInput = document.getElementById("phone-input")
    const hiddenInput = document.getElementById("phone-full-value")
    if (!phoneInput || typeof intlTelInput === "undefined") return

    const iti = intlTelInput(phoneInput, {
      initialCountry: "ar",
      preferredCountries: ["ar", "br", "cl", "co", "mx", "uy", "py", "pe", "us", "es"],
      separateDialCode: false,
      nationalMode: false,
      useFullscreenPopup: false,
      loadUtilsOnInit: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.8.1/build/js/utils.js",
    })

    const form = phoneInput.closest("form")
    if (form) {
      form.addEventListener("submit", function () {
        hiddenInput.value = iti.getNumber()
      })
    }
  })
</script>
