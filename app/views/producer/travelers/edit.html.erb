<h1 class="text-3xl font-bold mb-6">Editar Cliente</h1>

<%= simple_form_for [:producer, @traveler], html: { class: "bg-white p-6 rounded-lg shadow max-w-lg" } do |f| %>
  <%= f.input :first_name, label: "Nombre" %>
  <%= f.input :last_name, label: "Apellido" %>
  <%= f.input :email, label: "Email" %>
  <%= f.input :phone, label: "Teléfono" %>
  <%= f.input :document, label: "Documento" %>
  <%= f.input :birth_date, label: "Fecha de nacimiento", as: :datepicker %>

  <div class="flex gap-2">
    <%= f.button :submit, "Actualizar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", producer_travelers_path, class: "btn btn-ghost" %>
  </div>
<% end %>
