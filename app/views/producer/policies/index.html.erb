<h1 class="text-3xl font-bold mb-6">Pólizas Emitidas</h1>

<div class="overflow-x-auto bg-base-100 shadow rounded-box">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>Número</th>
        <th>Proveedor</th>
        <th>Prima</th>
        <th>Tu Comisión</th>
        <th>Estado Comisión</th>
        <th>Emitida</th>
      </tr>
    </thead>
    <tbody>
      <% @policies.each do |policy| %>
        <tr>
          <td><%= policy.policy_number %></td>
          <td><%= policy.quote_result.provider.name %></td>
          <td><%= policy.premium.format %></td>
          <td class="text-success font-semibold"><%= policy.producer_commission.format %></td>
          <td>
            <span class="badge badge-<%= policy.pending_commission? ? 'warning' : policy.paid_commission? ? 'success' : 'info' %>">
              <%= policy.producer_commission_status.humanize %>
            </span>
          </td>
          <td><%= l policy.issued_at, format: :short if policy.issued_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
