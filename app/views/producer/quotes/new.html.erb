<% content_for(:head) do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>.wizard-root, .wizard-root * { font-family: 'Outfit', sans-serif; }</style>
<% end %>

<div class="wizard-root max-w-4xl mx-auto py-6" data-controller="quote-form">

  <div class="wizard-card p-6 md:p-8 wizard-animate-in">
    <%= simple_form_for [:producer, @quote],
        html: { novalidate: true, data: { action: "submit->quote-form#validate" } } do |f| %>

      <%# ── Encabezado ── %>
      <div class="flex items-start gap-3.5 mb-6">
        <div class="wizard-icon-badge travel">
          <i class="ti ti-plane-departure text-xl"></i>
        </div>
        <div>
          <h2 class="wizard-section-title">Nueva cotización</h2>
          <p class="wizard-section-subtitle mt-0.5">Completá el viaje y las edades de los pasajeros para cotizar con todos los proveedores.</p>
        </div>
      </div>

      <%= f.hidden_field :travelers_count, data: { quote_form_target: "count" } %>

      <%# ── Barra de cotización ── %>
      <div class="qbar grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12">
        <%# Origen %>
        <div data-controller="country-autocomplete"
             data-country-autocomplete-items-value="<%= countries_autocomplete_data %>"
             class="ac-wrapper lg:col-span-3">
          <%= f.input :origin, label: "Origen", wrapper: :qbar,
              placeholder: "Ej: Argentina",
              input_html: {
                required: true, autocomplete: "off",
                data: {
                  country_autocomplete_target: "input",
                  action: "input->country-autocomplete#filter focus->country-autocomplete#open keydown->country-autocomplete#keydown focus->quote-form#clearError"
                }
              } %>
          <ul data-country-autocomplete-target="list" class="ac-list hidden"></ul>
        </div>

        <%# Destino %>
        <div data-controller="country-autocomplete"
             data-country-autocomplete-items-value="<%= countries_autocomplete_data %>"
             class="ac-wrapper lg:col-span-3">
          <%= f.input :destination, label: "Destino", wrapper: :qbar,
              placeholder: "Ej: Europa",
              input_html: {
                required: true, autocomplete: "off",
                data: {
                  country_autocomplete_target: "input",
                  action: "input->country-autocomplete#filter focus->country-autocomplete#open keydown->country-autocomplete#keydown focus->quote-form#clearError"
                }
              } %>
          <ul data-country-autocomplete-target="list" class="ac-list hidden"></ul>
        </div>

        <%# Fechas %>
        <div class="qbar-field lg:col-span-4">
          <span class="qbar-label"><i class="ti ti-calendar-event"></i> Fecha de viaje</span>
          <div class="qbar-dates">
            <%= f.input :departure_date, label: false, as: :datepicker, wrapper: :qbar_plain,
                placeholder: "Salida",
                input_html: { required: true,
                              data: { datepicker_min_value: Date.today.iso8601,
                                      action: "focus->quote-form#clearError" } } %>
            <i class="ti ti-arrow-narrow-right qbar-dates-sep"></i>
            <%= f.input :return_date, label: false, as: :datepicker, wrapper: :qbar_plain,
                placeholder: "Regreso",
                input_html: { data: { datepicker_min_value: Date.today.iso8601 } } %>
          </div>
        </div>

        <%# Tipo de viaje %>
        <div class="lg:col-span-2">
          <%= f.input :trip_type, label: "Tipo de viaje", wrapper: :qbar,
              collection: [["Viaje único", "single"], ["Multi-viaje", "multi_trip"], ["Anual", "annual"]],
              include_blank: false %>
        </div>

        <%# Edades %>
        <div class="qbar-field lg:col-span-12">
          <span class="qbar-label">
            <i class="ti ti-users"></i> Edades de los pasajeros
            <button type="button" class="qbar-add ml-1"
                    aria-label="Agregar pasajero"
                    data-quote-form-target="addBtn"
                    data-action="quote-form#add">
              <i class="ti ti-plus"></i>
            </button>
          </span>
          <div class="qbar-ages" data-quote-form-target="ages">
            <% 6.times do |i| %>
              <div class="qbar-age" data-age-field>
                <input type="number" name="quote[metadata][ages][]" min="0" max="120"
                       placeholder="—" required inputmode="numeric"
                       aria-label="Edad del pasajero <%= i + 1 %>"
                       data-action="focus->quote-form#clearError">
                <button type="button" class="qbar-age-remove hidden" tabindex="-1"
                        aria-label="Quitar pasajero" data-action="quote-form#remove">
                  <i class="ti ti-x"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="wizard-divider"></div>

      <%# ── Viajero principal (opcional) ── %>
      <div class="flex items-start gap-3.5 mb-5">
        <div class="wizard-icon-badge contact">
          <i class="ti ti-user text-xl"></i>
        </div>
        <div>
          <h2 class="wizard-section-title">Viajero principal</h2>
          <p class="wizard-section-subtitle mt-0.5">Opcional &mdash; podés completar estos datos luego al compartir la cotización.</p>
        </div>
      </div>

      <div class="wizard-optional-section p-4 md:p-5">
        <%= f.association :traveler, collection: current_user.travelers,
            label: "Viajero existente",
            include_blank: "Crear nuevo",
            wrapper: :select %>

        <%= f.simple_fields_for :traveler do |tf| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-5 gap-y-0">
            <%= tf.input :first_name, label: "Nombre", placeholder: "Juan" %>
            <%= tf.input :last_name, label: "Apellido", placeholder: "Pérez" %>
            <%= tf.input :email, label: "Email", placeholder: "juan@ejemplo.com" %>
            <%= tf.input :phone, label: "Teléfono", placeholder: "+54 9 11 1234-5678" %>
            <%= tf.input :document, label: "Documento", placeholder: "DNI o Pasaporte" %>
            <%= tf.input :birth_date, label: "Fecha de nacimiento", as: :datepicker %>
          </div>
        <% end %>
      </div>

      <%# ── Acciones ── %>
      <div class="flex items-center justify-end gap-2.5 mt-8 pt-5" style="border-top: 1px solid var(--wz-border);">
        <%= link_to "Cancelar", producer_quotes_path, class: "wizard-nav-btn btn btn-ghost btn-sm" %>
        <button type="submit" class="wizard-nav-btn btn btn-primary btn-sm gap-1.5">
          <i class="ti ti-search text-base"></i>
          Cotizar ahora
        </button>
      </div>

    <% end %>
  </div>
</div>
