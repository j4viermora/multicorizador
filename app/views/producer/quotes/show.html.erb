<%= turbo_stream_from @quote, :results %>

<div class="flex flex-wrap items-start justify-between gap-3 mb-2">
  <div>
    <h1 class="text-3xl font-bold">Cotización #<%= @quote.id %></h1>
    <p class="text-gray-500 mt-1">
      <i class="ti ti-plane-departure"></i>
      <%= @quote.origin %> → <%= @quote.destination %>
      <span class="mx-1">·</span>
      <%= l @quote.departure_date %><%= " – #{l @quote.return_date}" if @quote.return_date %>
      <span class="mx-1">·</span>
      <%= pluralize(@quote.travelers_count, "viajero", plural: "viajeros") %>
    </p>
  </div>
  <span class="badge badge-lg badge-<%= quote_status_color(@quote.status) %>">
    <%= @quote.status.humanize %>
  </span>
</div>

<div class="mt-6">
  <%= render "producer/quotes/results", quote: @quote %>
</div>

<div class="mt-8 flex gap-2">
  <%= link_to producer_quotes_path, class: "btn btn-ghost" do %>
    <i class="ti ti-arrow-left"></i>Volver
  <% end %>
  <% if @quote.editable? %>
    <%= link_to edit_producer_quote_path(@quote), class: "btn btn-outline" do %>
      <i class="ti ti-pencil"></i>Editar
    <% end %>
  <% end %>
</div>
