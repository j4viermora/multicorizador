<h1 class="text-3xl font-bold mb-6">Editar Cotización #<%= @quote.id %></h1>

<%= simple_form_for [:producer, @quote], html: { class: "bg-white p-6 rounded-lg shadow max-w-2xl" } do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <%= f.input :origin, label: "Origen" %>
    <%= f.input :destination, label: "Destino" %>
    <%= f.input :departure_date, label: "Fecha de salida", as: :datepicker,
                input_html: { data: { datepicker_min_value: Date.today.iso8601 } } %>
    <%= f.input :return_date, label: "Fecha de regreso", as: :datepicker,
                input_html: { data: { datepicker_min_value: Date.today.iso8601 } } %>
    <%= f.input :travelers_count, label: "Viajeros", input_html: { min: 1 } %>
    <%= f.input :trip_type, label: "Tipo de viaje", collection: [["Único", "single"], ["Multi-viaje", "multi_trip"], ["Anual", "annual"]], include_blank: false %>
  </div>

  <div class="flex gap-2">
    <%= f.button :submit, "Actualizar", class: "btn btn-primary" %>
    <%= link_to "Cancelar", producer_quotes_path, class: "btn btn-ghost" %>
  </div>
<% end %>
