<h1 class="text-3xl font-bold mb-6">Mis Facturas de Comisión</h1>

<div class="overflow-x-auto bg-base-100 shadow rounded-box">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>Período</th>
        <th>Total Comisión</th>
        <th>Estado</th>
        <th>Pagado</th>
      </tr>
    </thead>
    <tbody>
      <% @invoices.each do |invoice| %>
        <tr>
          <td><%= l invoice.period_start %> - <%= l invoice.period_end %></td>
          <td class="font-semibold"><%= invoice.total_commission.format %></td>
          <td>
            <span class="badge badge-<%= invoice.draft? ? 'ghost' : invoice.pending? ? 'warning' : 'success' %>">
              <%= invoice.status.humanize %>
            </span>
          </td>
          <td><%= invoice.paid_at ? l(invoice.paid_at, format: :short) : "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
